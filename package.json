{
  "name": "drone-racing-vr",
  "version": "1.0.0",
  "description": "Jogo de corrida de drone em VR para Meta Quest 3 usando A-Frame",
  "main": "index.html",
  "scripts": {
    "start": "npx http-server -p 8080 -c-1 --cors",
    "dev": "npx live-server --port=8080 --no-browser --cors",
    "build": "echo 'Build process - minify and optimize files'",
    "test": "echo 'Run tests for VR compatibility'",
    "deploy": "echo 'Deploy to web server'"
  },
  "keywords": [
    "aframe",
    "vr",
    "drone",
    "racing",
    "meta-quest",
    "webxr",
    "game",
    "3d"
  ],
  "author": "Desenvolvedor VR",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/seu-usuario/drone-racing-vr.git"
  },
  "bugs": {
    "url": "https://github.com/seu-usuario/drone-racing-vr/issues"
  },
  "homepage": "https://github.com/seu-usuario/drone-racing-vr#readme",
  "devDependencies": {
    "http-server": "^14.1.1",
    "live-server": "^1.2.2"
  },
  "dependencies": {},
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ],
  "webxr": {
    "supportedDevices": [
      "Meta Quest 3",
      "Meta Quest 2",
      "Meta Quest Pro",
      "Oculus Rift",
      "HTC Vive",
      "Valve Index"
    ],
    "features": [
      "hand-tracking",
      "controller-input",
      "room-scale",
      "seated"
    ]
  },
  "performance": {
    "targetFPS": 90,
    "maxPolygons": 100000,
    "textureResolution": "1024x1024"
  }
}